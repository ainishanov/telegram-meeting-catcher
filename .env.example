# Telegram API credentials from https://my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_SESSION_STRING=

# Only selected chats are watched. Use usernames without @ or numeric IDs.
TMC_ALLOWED_CHATS=
TMC_IGNORED_CHATS=

# Google Calendar OAuth credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Optional OpenAI-compatible extraction fallback.
# Leave empty to run deterministic-only mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Safety defaults.
TMC_TIMEZONE=Europe/Moscow
TMC_DEFAULT_DURATION_MINUTES=45
TMC_AUTO_CREATE_MIN_CONFIDENCE=0.82
TMC_REVIEW_MIN_CONFIDENCE=0.55
TMC_STATE_DIR=data
